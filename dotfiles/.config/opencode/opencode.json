{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["bun", "x", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "grep *": "allow"
    },
    "edit": "allow"
  }
}
