{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["bun", "x", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
