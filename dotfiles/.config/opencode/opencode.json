{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["bun", "x", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "xargs *": "allow",
      "find *": "allow",
      "sed *": "allow",
      "grep *": "allow",
      "gem *": "allow",
      "bundle *": "allow",
      "docker *": "allow",
      "git *": "allow",
      "npm *": "allow",
      "openspec *": "allow",
      "make *": "allow",
      "gh *": "allow",
      "curl *": "allow",
      "wget *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
