{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "compaction": {
      "model": "fireworks-ai/accounts/fireworks/models/minimax-m2p7"
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    "notionMCP": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "smartbear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@smartbear/mcp@latest"
      ],
      "enabled": false
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000
          }
        },
        "gpt-5.4-fast": {
          "limit": {
            "context": 1050000,
            "input": 272000,
            "output": 128000
          }
        }
      }
    }
  }
}
