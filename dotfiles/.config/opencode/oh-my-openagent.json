{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "fireworks-ai/accounts/fireworks/models/kimi-k2p6",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5-fast",
          "variant": "high"
        },
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "fireworks-ai/accounts/fireworks/models/kimi-k2p6",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5-fast",
          "variant": "medium"
        },
        "openai/gpt-5.4-mini-fast"
      ]
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    }
  },
  "experimental": {
    "preemptive_compaction": true
  },
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      429,
      503,
      529
    ],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 300,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "artistry": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    }
  }
}
